bindkey -s '^g' 'cd ~/Workspace\n'

# Multiline editing - Option+Enter inserts newline without executing
bindkey '^[^M' self-insert-unmeta

# Dev-Tools update function
devtools-update() {
    echo "🔄 Updating dev-tools..."

    # Save current directory
    local current_dir=$(pwd)

    # Run the update script
    if [[ -f "$BBOTIROFF_DEV_TOOL_PATH/update.sh" ]]; then
        bash "$BBOTIROFF_DEV_TOOL_PATH/update.sh"

        # Reload shell configuration
        echo "Reloading shell configuration..."
        source ~/.zshrc
        echo "✅ Dev-tools updated and reloaded!"
    else
        echo "❌ Error: Update script not found at $BBOTIROFF_DEV_TOOL_PATH/update.sh"
        echo "Please ensure dev-tools is properly installed"
        return 1
    fi

    # Return to original directory
    cd "$current_dir"
}

# Alias for quick update
alias dtu='devtools-update'

# devtool: subcommand dispatcher (replaces the old `code` alias)
devtool() {
    local subcommand="$1"
    case "$subcommand" in
        update)
            shift
            devtools-update "$@"
            ;;
        help|--help|-h)
            echo "Usage: devtool [command]"
            echo ""
            echo "Commands:"
            echo "  (no args)   Open dev-tools repo in VS Code"
            echo "  update      Pull latest changes and run update.sh (alias: dtu)"
            echo "  help        Show this message"
            ;;
        "")
            code "$BBOTIROFF_DEV_TOOL_PATH"
            ;;
        *)
            echo "devtool: unknown subcommand '$subcommand'"
            echo "Run 'devtool help' for usage"
            return 1
            ;;
    esac
}